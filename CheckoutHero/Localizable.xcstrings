{
  "sourceLanguage" : "en",
  "strings" : {
    "·" : {
      "comment" : "A period used to separate different pieces of information in a list.",
      "isCommentAutoGenerated" : true
    },
    "%@, checked" : {
      "comment" : "A toggleable checkbox that indicates whether a shopping item is selected.",
      "isCommentAutoGenerated" : true
    },
    "%@, unchecked" : {
      "comment" : "A label that indicates whether a shopping item is checked or unchecked.",
      "isCommentAutoGenerated" : true
    },
    "%lld items" : {
      "comment" : "A sublabel below a list item's title that shows the number of items in the list. The argument is the count of items in the list.",
      "isCommentAutoGenerated" : true
    },
    "^[%lld item](inflect: true)" : {
      "comment" : "A text element that shows the number of items in a shopping list, optionally pluralized. The argument is the count of items in the list.",
      "isCommentAutoGenerated" : true
    },
    "0" : {
      "comment" : "A text field for editing a price.",
      "isCommentAutoGenerated" : true
    },
    "1" : {
      "comment" : "A text field and picker for editing the quantity of a shopping item.",
      "isCommentAutoGenerated" : true
    },
